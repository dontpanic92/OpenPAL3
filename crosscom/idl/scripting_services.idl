[uuid(302fd52d-e93d-45e3-bfb3-719b94f2b215)]
interface IAppService: IUnknown {
    IDirector? open_game(int ordinal);
    void exit();

    // Sets the platform window title. Lets per-game launch scripts
    // (e.g. `openpal5.p7::launch`) re-brand the live application
    // without a Rust-side per-game `IApplicationLoaderComponent`.
    void set_title(&str title);
}
[uuid(8c4d50aa-3b07-4a32-9d20-2e0b2f7c0003)]
class AppService: IAppService {}

[uuid(8c4d50aa-3b07-4a32-9d20-2e0b2f7c0001)]
interface IConfigService: IUnknown {
    &str get_asset_path(&str config_key);
    void set_asset_path(&str config_key, &str path);
    bool save();
    void reload();
    &str pick_folder(&str initial);

    // Show a "save file" dialog and return the chosen absolute path
    // (empty string if cancelled). `default_name` pre-fills the
    // suggested filename in the dialog; `ext_filter` is a single
    // extension (e.g. "glb") used to build the dialog's type filter.
    &str pick_save_file(&str initial, &str default_name, &str ext_filter);

    // Theme name persisted under `config_key` (recognised keys are
    // "yaobow" and "editor"). Empty string means "use the built-in
    // default". Pair with `apply_theme` to also push it to the live UI.
    &str get_theme(&str config_key);
    void set_theme(&str config_key, &str name);

    // Apply `name` to the live imgui context. Persistence is separate —
    // callers usually do `set_theme(...); apply_theme(...); save();`.
    // Unknown names fall back to the built-in default.
    void apply_theme(&str name);

    // Names of every embedded theme, addressed by index. Order matches
    // `available_theme_count()`; out-of-range indices return "".
    int available_theme_count();
    &str available_theme_at(int index);

    // Scene-rendering scale mode persisted under `[render]` in
    // `yaobow.toml`. Returned/accepted as the lowercase enum string
    // ("native" or "logical"); other values silently behave as
    // "native". The engine reads this value once at startup, so a
    // change here only takes effect after the user restarts the
    // application — pair with a "restart required" UI hint.
    &str get_scene_scale_mode();
    void set_scene_scale_mode(&str mode);
}

