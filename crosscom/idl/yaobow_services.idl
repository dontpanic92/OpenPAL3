// Foreign service surface for the yaobow main app. The root script
// receives one app-lifetime context (the canonical `IHostContext`) at
// `app.p7:init(ctx)` and feature modules reuse that context instead of
// receiving page-specific service bundles from Rust.

module(rust) yaobow::comdef::yaobow_services;

import crosscom.idl;
import radiance.idl;
import scripting_services.idl;
import pal4_debug.idl;
import openpal4.idl;
import openpal5.idl;

// App-lifetime script root. The Yaobow protosept project's `app.p7`
// conforms a single struct to this proto; Rust holds the rooted
// instance and asks it to materialise per-feature surfaces (title
// director, PAL4 debug overlay, …).
[uuid(31f1b8d2-9b50-4c0e-9bd3-1c3d2e3f4a04), protosept(script_app_root)]
interface IYaobowScriptApp: IUnknown {
    IImmediateDirector make_title_director();
    IPal4DebugOverlay make_pal4_debug_overlay(IPal4DebugContext ctx);
    IPal4ActorController make_actor_controller(
        IPal4GameContext game_ctx,
        IInputService input,
        IEntity entity_0,
        IEntity entity_1,
        IEntity entity_2,
        IEntity entity_3,
        IPal4ActorAnimationController anim_0,
        IPal4ActorAnimationController anim_1,
        IPal4ActorAnimationController anim_2,
        IPal4ActorAnimationController anim_3,
        ICameraControl camera,
        IRayCaster ray_caster);

    // OpenPAL5 launch entry. The Rust caller constructs an
    // `IPal5Context` carrying the PAL5-specific state (asset path +
    // component factory used internally by the AssetLoader); the
    // script orchestrator (`yaobow/yaobow/scripts/openpal5.p7`)
    // drives the launch sequence through the canonical
    // `IHostContext` services: set title, build the default scene,
    // push it onto the scene manager, install a script-implemented
    // free-view director.
    void launch_openpal5(IPal5Context ctx);
}
[uuid(31f1b8d2-9b50-4c0e-9bd3-1c3d2e3f4a05)]
class YaobowScriptApp: IYaobowScriptApp {}

// Empty conforming class so tests + integration code can register
// their own structs as `IHostContext` via `ComObject_YaobowAppContext!`
// without re-introducing an app-specific interface. Production code
// uses `radiance_scripting::services::HostContext` directly.
[uuid(31f1b8d2-9b50-4c0e-9bd3-1c3d2e3f4a06)]
class YaobowAppContext: IHostContext {}
