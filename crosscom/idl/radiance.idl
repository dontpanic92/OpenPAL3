// `IRayCaster` exposes axis-aligned ray-casting against a triangle
// mesh collider set as a scriptable proto. The host implementation
// wraps a `RayCaster` (radiance::utils::ray_casting::RayCaster) and
// surfaces only the cast helpers the script side actually needs.
//
// The single method exposed today is the downward (NY-direction)
// floor cast used by PAL4's actor controller: returns the distance
// from `(ox, oy, oz)` to the first hit triangle along `-Y`, or
// `null` when nothing is below the origin.
[uuid(77d1815c-7042-4e4c-b849-440c75363dec)]
interface IRayCaster: IUnknown {
    float? cast_aa_ny(float ox, float oy, float oz);
}

[uuid(509149f3-51fc-4faa-ac3a-f84ca272c506)]
class ScriptRayCaster: IRayCaster {}

// `ICameraControl` exposes the scene camera's writable transform +
// orthonormal basis to scripts. The host implementation wraps the
// scene's `Camera::transform`, applying the same `set_position` /
// `look_at` operations that Rust callers would.
//
// `forward_*` / `right_*` return the camera-local axes as
// world-space unit vectors so script-side movement math (e.g. the
// PAL4 player controller's camera-relative WASD walking) can stay
// out of the host.
[uuid(55f53f18-79ee-4ded-8c0d-d0b25387a69b)]
interface ICameraControl: IUnknown {
    void set_position(float x, float y, float z);
    void look_at(float x, float y, float z);
    float forward_x();
    float forward_y();
    float forward_z();
    float right_x();
    float right_y();
    float right_z();
}

[uuid(d9b4c3f7-bd44-4cde-8fa8-8e1adec786b3)]
class SceneCameraControl: ICameraControl {}

// =====================================================================
// Editor-UI scripting host service (originally in immediate_director.idl).
//
// IUiHost: immediate-mode imgui surface exposed to p7 scripts. Pairing
// widgets (window, child_window, table, tab_bar, ...) take a trailing
// IAction body that runs *between* the host's begin_*/end_* calls. The
// Rust impl guarantees pairing via RAII (imgui-rs scope-guard closures).
// Scripts pass callbacks as ordinary p7 closures, elaborated into anon
// structs implementing IAction via SAM coercion.
//
// IImmediateDirector: engine-visible immediate-mode director. Inherits
// from IDirector and adds a render_im step the engine pumps inside its
// imgui frame scope. Scripts implement this directly via
// struct[radiance.IImmediateDirector]; the resulting box is wrapped to
// ComRc<IDirector> via the auto-generated wrap_immediate_director.
// =====================================================================

[uuid(7d3c8a44-58f1-4d12-9c4b-1a2f9c0e0d01)]
interface IUiHost: IUnknown {
    // --- Pairing widgets ---------------------------------------------
    // Body runs between begin/end; if the begin returns false (e.g.
    // window is collapsed) the body is *not* invoked, and the matching
    // end is still emitted via RAII.

    void window(&str title, float w, float h, int flags, IAction body);
    void window_centered(&str title, float w, float h, IAction body);
    void window_fullscreen(&str title, int flags, IAction body);
    void child_window(&str id, float w, float h, IAction body);
    void table(&str id, int cols, IAction body);
    void tab_bar(&str id, IAction body);
    void tree_node(&str label, IAction body);
    void group(IAction body);
    void style_alpha(float alpha, IAction body);

    // Push an imgui style color for the duration of `body` and pop
    // it on exit. `slot` matches the `imgui::StyleColor` enum values
    // exposed by imgui-rs:
    //   0 = Text                         21 = Button
    //   2 = WindowBg                     22 = ButtonHovered
    //                                    23 = ButtonActive
    // Out-of-range slots are clamped to `Text`. Multiple nested
    // calls compose as stacked pushes; ordering matches the begin/end
    // pairing imgui-rs's RAII tokens enforce.
    void style_color(int slot, float r, float g, float b, float a, IAction body);

    // Push a font for the duration of `body` and pop it afterwards.
    // `font_idx` selects from the host's font table; out-of-range
    // indices fall back to the default (index 0). Use this to render
    // a whole subtree (e.g. a debug overlay) at a non-default size
    // without sprinkling `text_with_font` over every leaf widget.
    void with_font(int font_idx, IAction body);

    // tab_item: body runs only while the tab is selected; the close
    // flag is reported as the return value (true == user requested
    // close on this frame).
    bool tab_item(&str label, bool closable, IAction body);

    // --- Layout primitives --------------------------------------------

    void same_line();
    void dummy(float w, float h);
    void spacer(float w, float h);

    // Absolute cursor positioning inside the current window's
    // content region, in script (logical) pixels. The host applies
    // `dpi_scale` internally. Pair `set_cursor_pos(x, y)` with the
    // immediately-following widget call (e.g. `image`, `text`,
    // `button`) to draw at a fixed location 鈥?needed for screens
    // (like the yaobow title page) that build their own layout
    // arithmetic instead of relying on imgui auto-flow.
    void set_cursor_pos(float x, float y);
    float cursor_pos_x();
    float cursor_pos_y();

    // Total display size (in logical/script pixels) of the imgui
    // viewport, i.e. `ui.io().display_size / dpi_scale`. Useful for
    // fullscreen layouts that compute their own 16:9 letterboxing.
    int display_size_x();
    int display_size_y();

    // Measure a string under the currently-active font, returned in
    // script (logical) pixels. Used by the title page to size the
    // "press any key" blinking text and centre it inside its pane.
    float calc_text_size_x(&str s);
    float calc_text_size_y(&str s);

    // Advance to the next column inside the most recently opened
    // `table(...)` body. Cells in an imgui table do not auto-advance;
    // immediate-mode scripts must call `table_next_column()` before
    // every cell (the legacy retained-tree walker called it between
    // children automatically 鈥?that helper is gone in the
    // immediate-mode model).
    void table_next_column();

    // --- Leaf widgets ------------------------------------------------

    void text(&str s);
    void text_with_font(int font_idx, &str s);
    bool button(&str label, float w, float h);
    void image(int texture_com_id, float w, float h);
    void image_fit(int texture_com_id, float src_w, float src_h);

    // Blit a sub-region of a texture atlas at the current imgui cursor
    // position. `u0,v0` is the top-left and `u1,v1` the bottom-right
    // of the region in normalised [0,1] texture coordinates. Used by
    // the editor's PAL4 UI-layout previewer to draw each CEGUI
    // imageset image without uploading per-region copies; the entire
    // imageset PNG is uploaded once and every `<Image>` rect in the
    // .imageset definition becomes a `(u0,v0,u1,v1)` slice.
    void image_uv(int texture_com_id, float w, float h,
                  float u0, float v0, float u1, float v1);
    void multiline_text(&str content, float w, float h);
    bool tree_leaf(&str label);

    // Render only the rows of a large flat list that are actually
    // visible in the current scroll region, using `ImGuiListClipper`.
    // `count` is the total number of rows the script *would* render
    // without clipping. `body` is invoked once per visible row index;
    // inside the body the script reads the current index via
    // `list_clipped_index()`.
    //
    // Bodies must submit one *constant-height* widget per invocation
    // (the row); otherwise the clipper's height estimate breaks.
    // Variable-height children (e.g. nested expanded tree nodes)
    // belong outside the clipper.
    //
    // Using an index thread-local instead of `IIntAction` keeps the
    // callback as a plain `IAction` and avoids extending the script-
    // impl-arg CCW registry in `crosscom_protosept`.
    void list_clipped(int count, IAction body);
    int list_clipped_index();

    // Two-phase tree-node submission for hot paths that can't afford
    // to pay the per-call SAM-closure allocation cost of the
    // `tree_node(label, IAction body)` form (e.g. iterating thousands
    // of sibling directories per frame). `tree_node_open` submits an
    // imgui tree node with `label` and returns whether the node is
    // currently open. When it returns true, the caller is responsible
    // for emitting the body's widgets *and then* calling `tree_pop()`
    // to close the imgui tree-node scope. When it returns false the
    // caller emits nothing and does NOT call `tree_pop()`. This
    // mirrors imgui's native `TreeNode` / `TreePop` pairing and
    // bypasses crosscom's IAction CCW machinery.
    bool tree_node_open(&str label);
    void tree_pop();

    // --- Docking ------------------------------------------------------
    // Emit a fullscreen host window with an `igDockSpace` filling it,
    // running `body` inside so dockable child windows in the body
    // register with the dockspace. Matches `radiance_editor`'s
    // `MainPageDirector` pattern: pushes a transparent `WindowBg` for
    // the duration of `igDockSpace()` so the central node stays
    // see-through when populated.
    void dock_space(&str root_id, IAction body);

    // Open a regular dockable imgui window. Default flags; the user
    // (or `dock_layout_once`) can dock it into the active dockspace.
    void window_docked(&str title, IAction body);

    // One-shot layout helper. The first call for `root_id` builds a
    // 4-pane layout (Left | Center | Right with a Bottom strip under
    // the Center) and docks the named windows into each region.
    // Subsequent calls are no-ops, so the script can call it every
    // frame inside `dock_space`'s body without rebuilding the layout.
    // Ratios are fractions of the dockspace's total extent.
    void dock_layout_once(
        &str root_id,
        &str left_window,
        &str right_window,
        &str bottom_window,
        &str center_window,
        float left_ratio,
        float right_ratio,
        float bottom_ratio);

    // --- Mouse query ---------------------------------------------------
    // Reflect the imgui state of the *last* item submitted (typically
    // the just-drawn `image(...)`). Plus per-frame mouse deltas the
    // script uses for orbit/pan/zoom previews. `mouse_drag_delta_*`
    // returns the cumulative drag since the press; pair with
    // `reset_mouse_drag_delta(button)` after consumption so the next
    // frame yields incremental motion.
    //   button 0 = left, 1 = right, 2 = middle
    bool is_item_hovered();
    bool mouse_down(int button);
    float mouse_drag_delta_x(int button);
    float mouse_drag_delta_y(int button);
    void reset_mouse_drag_delta(int button);
    float mouse_wheel();

    // Aggregate "is any keyboard key OR mouse button currently held
    // down this frame" 鈥?the imgui-io equivalent of
    // `keys_down.iter().any(|&k| k) || mouse_down.iter().any(|&k| k)`.
    // Title screens that wait for "press any key to continue" read
    // this once per frame; tracking edge transitions (the press 鈫?
    // release 鈫?next-press sequence the legacy code used) is left to
    // the script.
    bool any_key_or_mouse_down();

    // --- Menus --------------------------------------------------------
    // Top-of-viewport menu bar (`igBeginMainMenuBar` / `igEndMainMenuBar`).
    // `body` typically calls `menu(...)` to register each top-level entry.
    // The bar is emitted outside the dockspace so it remains visible
    // regardless of the dock layout.
    void main_menu_bar(IAction body);

    // A clickable top-level or nested menu. `body` runs only when the
    // menu is open; nest `menu(...)` calls for submenus and finish with
    // `menu_item(...)` leaves.
    void menu(&str label, IAction body);

    // Menu leaf. `selected` controls whether a checkmark is shown next
    // to the label (used to indicate the currently-active option in
    // radio-style menus such as `View > Theme`). Returns true on the
    // frame the item is clicked.
    bool menu_item(&str label, bool selected);

    // --- Content region ----------------------------------------------
    // Available content region of the current container, in scaled
    // pixels. Useful when sizing widgets (e.g. an offscreen render
    // target's `ui.image(...)`) to fill the remaining space. Returned
    // as int because the primary consumer (`IRenderTarget.resize`)
    // takes integer pixel extents, and p7 doesn't have an implicit
    // float鈫抜nt cast.
    int content_region_avail_x();
    int content_region_avail_y();
}

// Engine-visible immediate-mode director. `render_im` is pumped by the
// engine inside its imgui frame scope (Phase D of director.md); the
// inherited `IDirector::activate` / `IDirector::update` remain the
// activation/transition contract.
[uuid(3cc6ab2c-0d00-499f-b59f-7e9d63abb136), protosept(scriptable)]
interface IImmediateDirector: IDirector {
    void render_im(IUiHost ui, float dt);
}
