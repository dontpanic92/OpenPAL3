module(rust) shared::openpal5::comdef;
module(protosept) shared.openpal5;

import crosscom.idl;
import radiance.idl;

// PAL5 launch service. Mirrors IPal3Service / ISwd5Service: a host-side
// COM object that builds the PAL5 story director (the Rust Lua-VM
// `Pal5StoryDirector` in `yaobow_lib::openpal5`). The director returned
// via `IDirector` is opaque to the script — the script (title dispatch)
// and Rust direct-boot both just install it on the scene manager.
//
// Not marked `[protosept(scriptable)]` — the script only calls into it.
//
// The conforming `class Pal5Service` lives in `yaobow_services.idl`
// (and is implemented in `yaobow_lib`), not here, because the PAL5 story
// runtime (`Pal5StoryDirector`, `Pal5ScriptContext`, agent dispatch)
// lives in `yaobow_lib::openpal5` and pulling it into `shared` would
// invert the crate dependency. The interface itself lives here so
// `IPal5Service` can be referenced symmetrically from
// `IYaobowHostContext.pal5()`.
//
// `game_ordinal` discriminates PAL5 vs PAL5Q because they ship different
// `.pkg` decryption keys (see `GameType::pkg_key`). Returns `null` when
// the director fails to build (e.g. missing assets at `asset_path`).
[uuid(57fa39fc-df8d-469e-9704-60848580343c)]
interface IPal5Service: IUnknown {
    IDirector? create_director(&str asset_path, int game_ordinal);
}
