module(rust) shared::openpal4::comdef;
module(protosept) shared.openpal4;

import crosscom.idl;
import radiance.idl;
import scripting_services.idl;
import pal4_debug.idl;

[uuid(f3d7f0fd-20ca-450c-bd66-ad019b984a54)]
interface IOpenPAL4Director: IDirector {
}

[uuid(981884a7-63e8-4ee1-96f1-6efd259ebe3b)]
class OpenPAL4Director: IOpenPAL4Director, IImmediateDirector {}

// Loading / mode-transition orchestrator. Single owner of every PAL4
// scene transition (menu -> story, story -> in-game scene swap via
// `giArenaLoad` / world map, and -- future -- story <-> battle).
// Owns the loading overlay; the only callsite that synchronously
// invokes `Pal4VmContext::load_scene`. On Done, returns the `next`
// director (newly-built story for menu boots, or the suspended
// source director resumed in place for round-trips), so all state
// the source director carries (VM, continuations, scene stack) is
// preserved by holding it as a `ComRc<IDirector>`.
[uuid(7f1a0c20-94d8-4d11-9b62-3a0e6c5b1f44)]
interface IPal4TransitionDirector: IDirector {
}

[uuid(2b5c0e10-3d4f-4a72-9c81-8f2a6b4d7e91)]
class Pal4TransitionDirector: IPal4TransitionDirector, IImmediateDirector {}

[uuid(f6d70031-86e7-4efa-b1c5-5196063441ea)]
interface IPal4ActorAnimationController: IComponent {
    void play_default();

    void unhold();
    bool animation_completed();

    // Script-facing animation bridge. `anim` follows
    // `Pal4ActorAnimation` (0 Idle, 1 Walk, 2 Run, 3 Unknown).
    // `config` follows `Pal4ActorAnimationConfig`
    // (0 OneTime, 1 Looping, 2 PauseOnHold). The companion
    // `current_id()` reads back the active animation as an int.
    void play_by_id(int anim, int config);
    int current_id();
}

[uuid(e262bcd6-41fd-4cfd-a2fd-7376421b6ae5)]
class Pal4ActorAnimationController: IPal4ActorAnimationController, IAnimationEventObserver {}

[uuid(9ccfa4a1-16f9-483c-95d8-6095fbf24e09), protosept(scriptable)]
interface IPal4ActorController : IComponent {
    void lock_control(bool lock);
}

[uuid(0687035c-b5f3-47e1-9e4a-80fbf57b3a7c)]
class Pal4ActorController: IPal4ActorController {}

// Script-implemented factory for the PAL4 launch surface. The yaobow
// `app.p7` struct conforms to this (in addition to
// `yaobow_services.IYaobowScriptApp`); `shared`'s `Pal4Service` holds
// one `ComRc<IPal4ScriptFactory>` (QI'd from the app factory) and calls
// these straight through the COM vtable — no Rust-side hook traits.
// Lives in `openpal4.idl` (not `yaobow_services.idl`) because all three
// are PAL4 domain surfaces that `shared` owns and must reference.
[uuid(7a3e1c20-5d44-4b8e-9f12-0a6b3c8d2e44), protosept(scriptable)]
interface IPal4ScriptFactory: IUnknown {
    IPal4ActorController make_actor_controller(
        IPal4GameContext game_ctx,
        IInputService input,
        IEntity entity_0,
        IEntity entity_1,
        IEntity entity_2,
        IEntity entity_3,
        IPal4ActorAnimationController anim_0,
        IPal4ActorAnimationController anim_1,
        IPal4ActorAnimationController anim_2,
        IPal4ActorAnimationController anim_3,
        ICameraControl camera,
        IRayCaster ray_caster);

    // Scripted PAL4 start-menu director. Returns `IImmediateDirector`
    // (the menu struct conforms to both `IImmediateDirector` and
    // `IDirector`); `Pal4Service::build_start_menu` QIs to `IDirector`.
    IImmediateDirector make_pal4_start_menu(&str asset_path);

    // Scripted PAL4 debug overlay built against a host-supplied
    // `IPal4DebugContext`. `Pal4Service` assembles the surrounding
    // `Pal4DebugBundle` (Rust-side session + state) around it.
    IPal4DebugOverlay make_pal4_debug_overlay(IPal4DebugContext ctx);

    // Scripted PAL4 loading overlay. Renders
    // `/gamedata/ui/layouts/loading.xml` while a scene transition is
    // pending so the synchronous `Pal4Scene::load` is hidden behind a
    // fullscreen layout. `OpenPAL4Director` owns the resulting box
    // and drives it from `update` / `render_im`.
    IPal4LoadingOverlay make_pal4_loading_overlay();
}

[uuid(b6f4d2a8-3c91-4e07-8a55-1d2e9f0c7b63)]
class Pal4ScriptFactory: IPal4ScriptFactory {}

// Scripted PAL4 loading overlay. Mirrors the `IPal4DebugOverlay`
// pattern: a `[protosept(scriptable)]` interface implemented by a p7
// struct, called every frame from Rust while a scene transition is
// being hidden behind the loading layout. The state machine + frame
// counter live in p7; the Rust director only drives:
//
//   1. `request(scene, block)` arms a fresh transition,
//   2. each `update()` calls `tick(dt)` and acts on the returned
//      phase (LOAD_READY → call host.pal4().request_scene_load
//      having already happened in step 1; the director performs the
//      actual `app.load_scene` synchronously this frame),
//   3. each `render_im` calls `render(ui, dt)` while `is_active()`
//      reports true so the loading layout paints over the frozen
//      scene.
//
// Phase codes returned from `tick`:
//   0 = LOAD_IDLE       no transition pending
//   1 = LOAD_PAINTING   overlay drawn but load not yet kicked
//   2 = LOAD_READY      caller must call `app.load_scene` this tick
//   3 = LOAD_HOLDING    load done, overlay holding minimum duration
//   4 = LOAD_DONE       overlay dismissed this tick (clears on read)
//
// `notify_load_complete` is called by the director immediately after
// performing the synchronous `app.load_scene`, so the overlay can
// transition `READY -> HOLDING` and start its dismissal timer.
[uuid(2c5b9d10-7f48-4e6b-9f3c-1d8e0a4b5c6d), protosept(scriptable)]
interface IPal4LoadingOverlay: IUnknown {
    void request(&str scene_name, &str block_name);
    int  tick(float dt);
    void notify_load_complete();
    bool is_active();
    void cancel();

    // Target progress in [0, 1]. The overlay eases its on-screen
    // bar fill toward this value. Calls are monotone in practice
    // (each stage of the transition raises the target), but the
    // overlay does not enforce monotonicity.
    void set_progress(float target);

    void render(IUiHost ui, float dt);
}

[uuid(2c5b9d10-7f48-4e6b-9f3c-1d8e0a4b5c6e)]
class Pal4LoadingOverlay: IPal4LoadingOverlay {}

// Host-implemented PAL4 game context handed to scripted controllers.
// Exposes only the truly PAL4-specific surface: the current party
// leader index (engine-driven via `Pal4AppContext::set_leader`) and
// per-scene event-trigger dispatch (walks the scene's
// `SceneEventTrigger` list and invokes each one's check callback).
//
// Everything else the player controller needs — input, ray casting,
// camera, the leader entity, animation — flows in through the
// generic scriptable engine protos (`IInputService`, `IRayCaster`,
// `ICameraControl`, `IEntity`, `IPal4ActorAnimationController`)
// at controller-construction time, not through this object.
[uuid(0687035c-b5f3-47e1-9e4a-80fbf57b3a7d)]
interface IPal4GameContext: IUnknown {
    // Current party-leader index (0..=3). Set by the engine via
    // `Pal4AppContext::set_leader`; only the actor controller whose
    // `player_id` matches drives input.
    int current_leader();

    // Walks every `SceneEventTrigger` registered for the current
    // scene, dispatching each one's check callback with the
    // pre-movement origin + per-frame movement vector.
    void check_event_triggers(
        float ox, float oy, float oz,
        float mx, float my, float mz);
}

[uuid(0687035c-b5f3-47e1-9e4a-80fbf57b3a7e)]
class Pal4GameContext: IPal4GameContext {}

// PAL4 launch service — phase-2 single-source-of-truth for PAL4
// director construction. Singleton-per-app installed by
// `YaobowApplicationLoader` and exposed via
// `IYaobowHostContext.pal4()`.
//
// `create_director(asset_path)` now returns the **start-menu**
// director (script-built via the `IYaobowScriptApp.make_pal4_start_menu`
// hook). The menu's "New Game" handler swaps itself for the full
// story director via `enter_new_game(asset_path)`, which
// holds the old construction body (asset loader, AS VM, agent
// bridge wiring, debug bundle, actor controller).
//
// `open_layout(vfs_path)` mints an `IUiLayoutHandle` against the
// per-launch vfs that `create_director` already mounted. Used by
// the start-menu director to render `MainWindow.xml`. Returns null
// when the per-launch vfs hasn't been installed yet (i.e. before
// `create_director` ran) or the path doesn't resolve / parse.
//
// The `AgentServer` HTTP listener itself stays owned by
// `YaobowApplicationLoader` for the app lifetime; `Pal4Service` only
// holds a `RefCell<Option<Rc<Pal4AgentBridge>>>` that the loader
// sets at boot when `--pal4 --agent-port` was passed. The service
// also holds a `Weak<YaobowScriptProject>` (not Rc) so the
// project↔host-context↔per-game-service ownership graph stays
// acyclic.
[uuid(60e42ff1-613a-4b0a-93c0-eada0bd0f9dd)]
interface IPal4Service: IUnknown {
    IDirector create_director(&str asset_path);
    IDirector enter_new_game(&str asset_path);

    // Like `enter_new_game`, but queues a load of save `slot`
    // (1-based, matching the JSON slot files under
    // `<save_dir>/OpenPAL4/Save/<slot>.json`) onto the fresh story
    // director. The load is applied on the director's first advancing
    // `update` (the same lifecycle point as the in-game save/load
    // hotkeys), so the saved scene/block/leader/position and the
    // story-plot script globals are restored before play resumes.
    // A missing or corrupt slot is non-fatal: the story director is
    // still returned (the load no-ops with a log), so the start menu's
    // load screen never dead-ends.
    IDirector enter_load_game(&str asset_path, int slot);

    IUiLayoutHandle? open_layout(&str vfs_path);

    // Number of save slots surfaced by the start-menu load screen.
    // Fixed at 4 to mirror the in-game Num1-Num4 / Num5-Num8 hotkey
    // slots.
    int save_slot_count();

    // True when `<save_dir>/OpenPAL4/Save/<slot>.json` exists and
    // deserializes into a `Pal4PersistentState`. Drives whether the
    // load screen renders the slot as selectable.
    bool save_slot_exists(int slot);

    // Display-ready load-screen row label for save `slot`, e.g.
    // "Slot 1 - m02/3 - Quest 42%" for a populated slot or
    // "Slot 1 - (empty)" for a missing/unreadable one. ASCII only
    // (the PAL4 menu font has no CJK glyphs).
    &str save_slot_summary(int slot);

    // Build a fresh `CoreScene` containing the ZJM start-menu backdrop:
    // ZJM.bsp + ZJM_water.dff + ZJM_trans.dff under
    // `/gamedata/ui/uiWorld/zjm/`, with the paired `.uva` animations
    // wired onto the animated surfaces as self-ticking
    // `UvAnimationComponent`s. The menu director just pushes the
    // returned scene; the engine animates it each frame while it is the
    // active scene, and popping it on deactivate tears it down so the
    // story director starts clean. Returns null when the per-launch vfs
    // is not mounted yet or the BSP cannot be loaded.
    IScene? load_menu_scene();

    // PAL4-specific BGM loader. Reads
    // `/gamedata/Music/<music_name>.smp` from the per-launch vfs,
    // unwraps the embedded `CpkArchive` entry, XXTEA-decrypts the
    // payload, and mints an `IAudioSource` whose decoder is fed the
    // resulting MP3 bytes. Returns null when the per-launch vfs is
    // not mounted, the file is missing, or decryption fails. The
    // returned source is auto-ticked by the engine just like every
    // other `IAudioSource`.
    IAudioSource? load_music(&str music_name);
}

[uuid(956d18ea-cffe-47f6-9458-ddb3b087110f)]
class Pal4Service: IPal4Service {}

