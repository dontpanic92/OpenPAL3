module(rust) shared::openpal5::comdef;

import crosscom.idl;
import radiance.idl;

// PAL5 launch service. PAL5's director stays script-implemented
// (the small `OpenPal5Director` in `openpal5_director.p7` is just a
// thin freeview camera driver — too small to bother Rust-ifying).
// So `IPal5Service` exposes data + setup helpers the script needs:
//
//   * `load_default_scene` returns the scene the script will push.
//   * `position_camera_default` sets the camera to the entry pose
//     (replaces the INITIAL_POS / INITIAL_LOOK constants previously
//     hard-coded in the script).
//
// The script-side `openpal5_director.make_pal5_director(host, path, ord)`
// helper calls these + boxes the script director + returns it.
//
// `game_ordinal` is needed because PAL5 and PAL5Q ship different `.pkg`
// decryption keys (see `GameType::pkg_key`).
[uuid(57fa39fc-df8d-469e-9704-60848580343c)]
interface IPal5Service: IUnknown {
    IScene? load_default_scene(&str asset_path, int game_ordinal);
    void position_camera_default();
}

[uuid(23cec375-5ad3-42e9-8f0e-7147c5329804)]
class Pal5Service: IPal5Service {}
