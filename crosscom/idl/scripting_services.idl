// Empty conforming class so radiance_scripting's own `ImguiUiHost` /
// `HostFacade` Rust types can mint a `ComRc<IUiHost>` via the locally
// generated `ComObject_UiHost!` macro. The `IUiHost` interface itself
// lives in `radiance.idl`; this class is just the ComObject vehicle
// that owns the macro expansion in this crate (the macro's
// `use crate as radiance_scripting;` requires the macro to be generated
// in the same crate it's invoked from).
[uuid(7d3c8a44-58f1-4d12-9c4b-1a2f9c0e0d02)]
class UiHost: IUiHost {}

// Read-only handle to a parsed CEGUI-style UI layout (PAL4
// `<GUILayout>` XML under `gamedata/ui/layouts/`). The host parses
// the layout + every referenced `.imageset`, uploads each imageset
// PNG to the imgui texture cache once, and exposes a flat pre-order
// draw list (with `AlwaysOnTop` children moved to the back) that the
// script-side renderer iterates with `ui.image_uv(...)`. `window_*`
// accessors surface the tree metadata for the inspector / debug
// dump.
//
// v1 covers static composition: each `<Window>` with an `Image`
// property emits exactly one draw cmd. Alt-state image slots
// (hover / pressed / disabled) are populated for interactive
// widgets.
//
// Two callers: `IPreviewerHub.open_ui_layout` (editor previewer tab)
// and `IPal4Service.open_layout` (PAL4 start-menu director). The
// interface lives here so its Rust impl can live in
// `radiance_scripting::services::ui_layout` and be reused by both.
[uuid(da12dcb1-4f74-4f51-9bff-1d5d3d3e1c19)]
interface IUiLayoutHandle: IUnknown {
    // Native canvas size as declared by the imagesets referenced by
    // the layout (PAL4 always uses 800x600). The script renderer
    // fits this 1:1 box into the available content region.
    int native_width();
    int native_height();

    // JSON dump of the parsed layout tree for the inspector tab.
    &str text_dump();

    // Flat draw list. Each index `i` in `[0, draw_count())` is a
    // single image quad at `(draw_x, draw_y)` with size
    // `(draw_w, draw_h)` (in native pixels), sampling the texture
    // identified by `draw_texture_com_id(i)` between `(u0,v0)` and
    // `(u1,v1)` UV. Ordering is the desired draw order (back-to-front).
    int draw_count();
    int draw_window_id(int i);
    float draw_x(int i);
    float draw_y(int i);
    float draw_w(int i);
    float draw_h(int i);
    int draw_texture_com_id(int i);
    float draw_u0(int i);
    float draw_v0(int i);
    float draw_u1(int i);
    float draw_v1(int i);

    // Alternate-state image slots. `0` for `texture_com_id` means
    // the state is not configured; the script renderer skips the
    // overlay in that case.
    int draw_hover_texture_com_id(int i);
    float draw_hover_u0(int i);
    float draw_hover_v0(int i);
    float draw_hover_u1(int i);
    float draw_hover_v1(int i);
    int draw_pressed_texture_com_id(int i);
    float draw_pressed_u0(int i);
    float draw_pressed_v0(int i);
    float draw_pressed_u1(int i);
    float draw_pressed_v1(int i);
    int draw_disabled_texture_com_id(int i);
    float draw_disabled_u0(int i);
    float draw_disabled_v0(int i);
    float draw_disabled_u1(int i);
    float draw_disabled_v1(int i);

    // True if the draw cmd corresponds to an interactive widget
    // (Button, Checkbox, ...) whose hover/press visuals should be
    // driven by mouse input over the rect.
    bool draw_is_interactive(int i);

    // Per-window text label. Empty string when the source window
    // has no `Text` property.
    &str draw_text(int i);
    bool draw_has_text(int i);

    // Animated-sequence frames for `OiramLook/StaticSequence` windows
    // carrying a `SegImage` property. `draw_frame_count(i)` returns 0
    // for plain (non-sequence) draws; the script renderer falls back
    // to the base image in that case. Frames are ordered by the
    // numeric suffix of the imageset entry (`juaner1, juaner2, ...`).
    int draw_frame_count(int i);
    int draw_frame_texture_com_id(int i, int frame);
    float draw_frame_u0(int i, int frame);
    float draw_frame_v0(int i, int frame);
    float draw_frame_u1(int i, int frame);
    float draw_frame_v1(int i, int frame);

    // Window-tree metadata, indexed in pre-order traversal of the
    // original XML (independent of the draw-list ordering above).
    int window_count();
    &str window_name(int i);
    &str window_type(int i);
}
// The concrete `class UiLayoutHandle: IUiLayoutHandle {}` lives in
// `shared_services.idl` so the ComObject macro generates in `shared`,
// next to the CEGUI parsers + the Rust impl
// (`shared::loaders::cegui::ui_layout_handle`).
