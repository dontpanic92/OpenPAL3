// Video playback handle. The Rust impl wraps a `Box<VideoPlayer>`
// (engine factory) + an `ImguiTextureCache` slot — `texture_com_id`
// re-binds the live GPU texture every call, so p7 can blit the
// current frame via `ui.image_fit(h.texture_com_id(), w, h)`. Shared
// across editor (preview tabs) and game (PAL3 intro movie).
//
// The concrete `class VideoHandle: IVideoHandle {}` lives in
// `yaobow_editor_services.idl` (and is implemented in
// `yaobow_editor::services::handles`); ports that need their own
// concrete class declare it in their own IDL.
//
// State codes: 0 = Stopped, 1 = Playing, 2 = Paused (mirrors
// `radiance::video::VideoStreamState`).
[uuid(da12dcb1-4f74-4f51-9bff-1d5d3d3e1c05), protosept(scriptable)]
interface IVideoHandle: IUnknown {
    void toggle();
    int state();
    int width();
    int height();
    int texture_com_id();

    // Total clip duration in milliseconds, 0 if unknown.
    int duration_ms();
    // Current playback position in milliseconds (within the current loop).
    int position_ms();
    // Seek to `ms` milliseconds. Clamped to `[0, duration_ms]`.
    void seek_ms(int ms);
    // Restart from the beginning. Works whether the stream is currently
    // Playing, Paused, or Stopped (post-EOF for a non-looping stream).
    void restart();
    // Stop playback (post-stop the stream can be restarted via `restart`).
    void stop();
    // Toggle loop at runtime without re-opening.
    void set_looping(bool looping);
    bool looping();
}

// Frame-by-frame GIF animation: pairs each frame's `ITexture` with
// its `delay_ms`. Returned by `ITextureService.load_gif_animation`
// so scripts (e.g. the yaobow title page's outline animation) can
// advance frames at the encoded cadence without losing the timing
// the raw `load_gif_frames` array drops.
[uuid(15a50631-5098-45ca-ac41-1036b48df399)]
interface IGifAnimation: IUnknown {
    int frame_count();
    ITexture frame_at(int i);
    int delay_ms(int i);
}
[uuid(15a50631-5098-45ca-ac41-1036b48df3a0)]
class GifAnimation: IGifAnimation {}

[uuid(15a50631-5098-45ca-ac41-1036b48df398)]
interface ITextureService: IUnknown {
    ITexture? load_png(&str vfs_path);
    IObjectArray? load_gif_frames(&str vfs_path);
    IGifAnimation? load_gif_animation(&str vfs_path);
}
[uuid(7807f40d-87f5-46f9-a479-32449fb4bb74)]
class TextureService: ITextureService {}

// =====================================================================
// Generic UI sprite layer (engine-level, game-agnostic).
//
// The north-star replacement for per-screen Rust "scene" objects
// (PAL3's retired `Pal3StartMenuScene` / `Pal3DialogBoxScene`): one
// reusable, opaque sprite handle plus a vfs-bound loader, mirroring how
// Unity/UE/Godot expose a generic `Sprite`/`Texture2D`/`RID` that every
// feature references instead of subclassing.
//
// Usage contract (the "cache-once, pass-id-per-frame" pattern):
//   1. A script loads its sprites ONCE (`load_sprite` / `load_atlas_page`
//      + `sprite`), stores each `ISprite`'s `com_id` + size + UV as plain
//      script values, and keeps the `box<ISprite>` alive for the
//      surface's lifetime.
//   2. Per frame it issues only `IUiHost.image_rect(com_id, ...)` /
//      `image_uv(...)` with the cached primitives — no per-frame getter
//      round-trips across the boundary.
//
// Lifetime: each handle is refcounted (ComRc / p7 box). The backing GPU
// texture is released through the `ImguiTextureCache`'s frame-gated
// deletion queue (after MAX_FRAMES_IN_FLIGHT (+1) presented frames), so
// dropping a handle mid-frame can never free a texture the GPU is still
// sampling.
// =====================================================================

// Opaque UI sprite: a (possibly sub-rect) view onto an uploaded atlas
// page. `com_id` is the `ImguiTextureCache` key to feed to
// `IUiHost.image_rect`/`image_uv`; `width`/`height` are the sub-rect's
// native pixel size; `u0..v1` are its normalised atlas coordinates
// (full `[0,1]` for a whole-image sprite). A sprite holds a strong
// reference to its page, so the page stays uploaded until the last
// sprite (and the page handle) drop.
[uuid(48874160-ffd0-443c-855a-f689eb2ddc60)]
interface ISprite: IUnknown {
    int com_id();
    int width();
    int height();
    float u0();
    float v0();
    float u1();
    float v1();
}
[uuid(24e14d91-6ad5-4a86-a7d8-ac47ddc9c5cc)]
class Sprite: ISprite {}

// An uploaded texture page. `sprite(x,y,w,h)` carves an `ISprite` over a
// pixel sub-rect (UVs computed with the half-texel inset to avoid atlas
// bleeding); `whole()` returns a sprite covering the entire page. The
// page's com_id is released (frame-gated) once the page handle and every
// sprite it minted have dropped.
[uuid(396e0261-1097-4750-9be8-d29a3029a88e)]
interface IAtlasPage: IUnknown {
    int width();
    int height();
    ISprite sprite(int x, int y, int w, int h);
    ISprite whole();
}
[uuid(8b8f8b3d-fcfe-4b84-a064-7e6f8462735b)]
class AtlasPage: IAtlasPage {}

// Generic sprite loader bound to a single vfs (e.g. a game's mounted
// `.cpk`). Decodes images (`image::load_from_memory` with a headerless-
// TGA fallback and the D3D9 bottom-up `.dds` vertical flip) and uploads
// them to the shared `ImguiTextureCache`. Returns `null` on missing /
// undecodable / upload-failed assets so callers degrade gracefully.
[uuid(d3c7d03e-9099-4ea6-8f1f-c091e615c855)]
interface ISpriteService: IUnknown {
    // Load a single full image as a one-sprite page (UV `[0,1]`).
    ISprite? load_sprite(&str vfs_path);
    // Load an atlas page to carve sub-rect sprites from.
    IAtlasPage? load_atlas_page(&str vfs_path);
}
[uuid(cb25a82b-1848-4708-b6ae-a6161dcb57f1)]
class SpriteService: ISpriteService {}


[uuid(fa71af91-765f-4fc4-a36d-63fcbe27c4f5)]
interface IVfsService: IUnknown {
    bool exists(&str vfs_path);
    int byte_len(&str vfs_path);
    int entry_count(&str vfs_path);
    // Number of entries in `vfs_path` that are directories. Returned
    // as a prefix count: the cached sorted_entries() listing places
    // all subdirs first, so files start at index `subdir_count(...)`.
    // Used by the resource tree to render subdirs with `tree_node` and
    // the (potentially-huge) file tail through `IUiHost.list_clipped`.
    int subdir_count(&str vfs_path);
    &str entry_name(&str vfs_path, int index);
    bool entry_is_dir(&str vfs_path, int index);
    bool is_dir(&str vfs_path);
    bool is_expanded(&str vfs_path);
    void toggle_expanded(&str vfs_path);
    int command_id(&str vfs_path);
    &str command_path(int command_id);
}
[uuid(f19e19aa-9568-4021-ae47-7658426780f2)]
class VfsService: IVfsService {}

[uuid(c0d98698-33e4-4503-a403-eb3573716ed0)]
interface IInputService: IUnknown {
    bool key_down(int keycode);
    bool key_pressed(int keycode);
    float mouse_x();
    float mouse_y();
    // Axis value in [-1.0, 1.0]. Axis codes mirror
    // `radiance::input::Axis`: LeftStickX=0, LeftStickY=1,
    // RightStickX=2, RightStickY=3.
    float axis(int axis_code);
    // Mouse buttons. Button codes mirror `radiance::input::MouseButton`:
    // Left=0, Right=1, Middle=2.
    bool mouse_button_down(int button);
    bool mouse_button_pressed(int button);
    // Cursor motion accumulated this frame, in raw screen pixels.
    float mouse_delta_x();
    float mouse_delta_y();
    // Wheel ticks accumulated this frame. One detent ≈ 1.0; positive
    // values scroll away from the user.
    float mouse_wheel();
}
[uuid(0993f2d2-6b91-4bbb-92ac-acd5e3ee94c4)]
class InputService: IInputService {}

